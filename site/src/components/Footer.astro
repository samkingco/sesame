---
import { GITHUB_URL } from "../config";
const year = new Date().getFullYear();
---

<footer class="mx-auto max-w-5xl px-6 py-12">
  <div class="flex flex-col items-center gap-2 text-sm">
    <nav class="flex gap-4">
      <a
        href="/privacy"
        class="underline decoration-dashed decoration-seed/30 hover:decoration-seed transition"
        >Privacy</a
      >
      <span aria-hidden="true" class="opacity-40">&bull;</span>
      <a
        href="/terms"
        class="underline decoration-dashed decoration-seed/30 hover:decoration-seed transition"
        >Terms</a
      >
      <span aria-hidden="true" class="opacity-40">&bull;</span>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="underline decoration-dashed decoration-seed/30 hover:decoration-seed transition"
      >
        GitHub
      </a>
    </nav>
    <p>&copy; {year} Sesame</p>
  </div>
</footer>
