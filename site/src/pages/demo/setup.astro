---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Base
  title="Set up 2FA — Gomashio Industries"
  description="Set up two-factor authentication for your Gomashio Industries account."
>
  <Header />
  <main class="flex flex-1 flex-col items-center justify-center px-2 sm:px-6 py-12">
    <div class="w-full max-w-sm">
      <header class="px-2 sm:px-6">
        <p class="text-sm">Set up 2FA</p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight">Gomashio Industries</h1>
        <p class="mt-2 text-sm">
          Scan the QR code with Sesame, then enter the code to verify.
        </p>
      </header>

      <div class="mt-6 rounded-xl ring-1 ring-black/5 bg-white p-6">
        <div class="flex flex-col items-center gap-4">
          <div id="qr-container" class="flex aspect-square w-full max-w-[240px]"></div>
          <code
            id="secret-display"
            class="select-all overflow-hidden text-ellipsis whitespace-nowrap font-mono text-xs text-center"
          ></code>
        </div>

        <form id="verify-form" class="mt-6 space-y-4">
          <div>
            <label class="block text-sm font-medium" for="totp-code">Authentication code</label>
            <input
              id="totp-code"
              type="text"
              inputmode="numeric"
              autocomplete="one-time-code"
              maxlength="6"
              pattern="[0-9]{6}"
              placeholder="000000"
              required
              class="mt-1 block h-10 w-full rounded-md ring-1 ring-black/10 bg-white px-3 font-mono tracking-widest placeholder:text-seed/30 focus:ring-black/10 focus:outline-none"
            />
            <p id="verify-error" class="mt-2 hidden text-sm text-red-600" role="alert">
              Code didn't match. Check your authenticator and try again.
            </p>
          </div>

          <button
            type="submit"
            class="h-10 w-full rounded-md bg-seed text-sm font-bold text-warm transition-opacity hover:opacity-90"
            >Verify</button
          >
        </form>
      </div>

      <p class="mt-8 text-center text-sm opacity-70">
        This is a <a
          href="/demo"
          class="underline decoration-dashed decoration-seed/30 hover:decoration-seed transition"
          >demo</a
        > only.
      </p>
    </div>
  </main>
  <Footer />
</Base>

<script>
  import qrcode from "qrcode-generator";
  import {
    getOrCreatePendingAccount,
    clearPendingAccount,
    saveAccount,
  } from "../../lib/demo-accounts";
  import { base32Decode, verifyTOTP } from "../../lib/totp";

  function init() {
    const account = getOrCreatePendingAccount();

    const container = document.getElementById("qr-container")!;
    const secretDisplay = document.getElementById("secret-display")!;

    const qr = qrcode(0, "M");
    qr.addData(account.otpAuthURI);
    qr.make();

    container.innerHTML = qr.createSvgTag({ scalable: true });
    const svg = container.querySelector("svg");
    if (svg) {
      svg.removeAttribute("width");
      svg.removeAttribute("height");
      svg.classList.add("w-full", "h-full");
    }

    secretDisplay.textContent = account.secret.replace(/(.{4})/g, "$1 ").trim();

    const form = document.getElementById("verify-form") as HTMLFormElement;
    const input = document.getElementById("totp-code") as HTMLInputElement;
    const error = document.getElementById("verify-error")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      error.classList.add("hidden");

      const code = input.value.trim();
      if (code.length !== 6) return;

      const secret = base32Decode(account.secret);
      const valid = await verifyTOTP(secret, code);

      if (valid) {
        saveAccount(account);
        clearPendingAccount();
        window.location.href = `/demo/welcome?account=${account.id}`;
      } else {
        error.classList.remove("hidden");
        input.value = "";
        input.focus();
      }
    });
  }

  init();
</script>
